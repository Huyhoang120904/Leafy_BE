    },
    {
      "name": "Device Management",
      "item": [
        {
          "name": "Get All User Devices",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    console.log('User devices:', JSON.stringify(jsonData.result, null, 2));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/devices",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "devices"]
            },
            "description": "Get list of all registered devices for the authenticated user. Shows device type, name, platform, last used time, etc."
          },
          "response": []
        },
        {
          "name": "Remove Specific Device",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/devices/:deviceId",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "devices", ":deviceId"],
              "variable": [
                {
                  "key": "deviceId",
                  "value": "{{deviceId}}",
                  "description": "Device ID to remove"
                }
              ]
            },
            "description": "Remove a specific device and blacklist its refresh token."
          },
          "response": []
        },
        {
          "name": "Remove All Other Devices",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/devices/others",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "devices", "others"]
            },
            "description": "Remove all devices except the current one. Useful for 'Sign out from all other devices' feature."
          },
          "response": []
        }
      ],
      "description": "Device management endpoints for viewing and managing user devices"
    },
    {
      "name": "Testing Scenarios",
      "item": [
        {
          "name": "Test: Login Same Device Type Twice",
          "item": [
            {
              "name": "1. Login as WEB (First Time)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Login successful', function() {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "if (pm.response.code === 200) {",
                      "    var jsonData = pm.response.json();",
                      "    pm.collectionVariables.set('accessToken', jsonData.result.accessToken);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "User-Agent",
                    "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
                  },
                  {
                    "key": "X-Device-ID",
                    "value": "web-device-001"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/auth/login",
                  "host": ["{{baseUrl}}"],
                  "path": ["auth", "login"]
                }
              },
              "response": []
            },
            {
              "name": "2. Login as WEB (Second Time - Should Logout First)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Login successful', function() {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "pm.test('Returns new tokens', function() {",
                      "    var jsonData = pm.response.json();",
                      "    pm.expect(jsonData.result.accessToken).to.exist;",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "User-Agent",
                    "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
                  },
                  {
                    "key": "X-Device-ID",
                    "value": "web-device-002"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/auth/login",
                  "host": ["{{baseUrl}}"],
                  "path": ["auth", "login"]
                },
                "description": "This should automatically logout the first WEB device and allow only one WEB device active."
              },
              "response": []
            },
            {
              "name": "3. Get Devices - Should Show Only One WEB",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Only one WEB device exists', function() {",
                      "    var jsonData = pm.response.json();",
                      "    var webDevices = jsonData.result.filter(d => d.deviceType === 'WEB');",
                      "    pm.expect(webDevices.length).to.equal(1);",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{accessToken}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/v1/devices",
                  "host": ["{{baseUrl}}"],
                  "path": ["v1", "devices"]
                }
              },
              "response": []
            }
          ],
          "description": "Test that logging in with same device type logs out the previous device"
        },
