                },
                "url": {
                  "raw": "{{baseUrl}}/auth/login",
                  "host": ["{{baseUrl}}"],
                  "path": ["auth", "login"]
                }
              },
              "response": []
            },
            {
              "name": "4. Get All Devices - Should Show 3 Types",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Three different device types exist', function() {",
                      "    var jsonData = pm.response.json();",
                      "    pm.expect(jsonData.result.length).to.equal(3);",
                      "    var types = jsonData.result.map(d => d.deviceType);",
                      "    pm.expect(types).to.include('WEB');",
                      "    pm.expect(types).to.include('MOBILE');",
                      "    pm.expect(types).to.include('TABLET');",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{accessToken}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/v1/devices",
                  "host": ["{{baseUrl}}"],
                  "path": ["v1", "devices"]
                }
              },
              "response": []
            }
          ],
          "description": "Test that multiple device types can coexist (WEB, MOBILE, TABLET, DESKTOP)"
        }
      ],
      "description": "Complete test scenarios for device management features"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
