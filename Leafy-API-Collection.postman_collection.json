        {
          "name": "Refresh Token - Web",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.result && jsonData.result.accessToken) {",
                  "        pm.collectionVariables.set('accessToken', jsonData.result.accessToken);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Cookie",
                "value": "refreshToken={{refreshToken}}",
                "description": "For web clients, refresh token is in cookie"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Refresh access token for web clients using HttpOnly cookie."
          },
          "response": []
        },
        {
          "name": "Refresh Token - Mobile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.result && jsonData.result.accessToken) {",
                  "        pm.collectionVariables.set('accessToken', jsonData.result.accessToken);",
                  "    }",
                  "    if (jsonData.result && jsonData.result.refreshToken) {",
                  "        pm.collectionVariables.set('refreshToken', jsonData.result.refreshToken);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
