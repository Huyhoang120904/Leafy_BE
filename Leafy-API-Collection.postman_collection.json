  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login - Web Browser",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.result && jsonData.result.accessToken) {",
                  "        pm.collectionVariables.set('accessToken', jsonData.result.accessToken);",
                  "        console.log('Access token saved:', jsonData.result.accessToken);",
                  "    }",
                  "    if (jsonData.result && jsonData.result.refreshToken) {",
                  "        pm.collectionVariables.set('refreshToken', jsonData.result.refreshToken);",
                  "        console.log('Refresh token saved:', jsonData.result.refreshToken);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "User-Agent",
                "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
                "description": "Desktop Chrome on Windows"
              },
              {
                "key": "X-Device-ID",
                "value": "{{deviceId}}",
                "description": "Unique device identifier"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"appVersion\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login from web browser (Chrome on Windows). Device type will be detected as WEB from User-Agent."
          },
          "response": []
        },
